# Database
POSTGRES_USER=adb_user
POSTGRES_PASSWORD=adb_password
POSTGRES_DB=adb_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# App
APP_ENV=development
SECRET_KEY=change_this_in_production
API_V1_PREFIX=/api/v1

# AI Models
YOLO_MODEL=yolov11n.pt
SAM2_MODEL=sam2_hiera_small.pt
LLM_MODEL=Qwen/Qwen2-VL-2B-Instruct

# Dataset Storage
DATASET_STORAGE_PATH=/app/datasets

# Optional: API keys for image search
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
